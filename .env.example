# Copy this file to .env and fill in your values. Do not commit .env.
#
#   cp .env.example .env
#
# Docker Compose reads this file and uses POSTGRES_* for the db service.
# The app uses DATABASE_URL (or builds it from POSTGRES_* if DATABASE_URL is unset).

# Postgres (used by Docker and by the app when DATABASE_URL is unset)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_DB=sensor_array_dev

# Ecto URL. Set this explicitly, or leave unset to build from POSTGRES_* above.
# DATABASE_URL=ecto://postgres:postgres@localhost/sensor_array_dev

# Optional: test database URL. If unset, tests use same host/user/password, db sensor_array_test.
# TEST_DATABASE_URL=ecto://postgres:postgres@localhost/sensor_array_test

# Dev server port (optional)
# PORT=4000
